# GCP Project
PROJECT_ID=your-project-id
REGION=us-central1

# Gemini API (direct, not via Agent Engine)
GEMINI_API_KEY=your-gemini-api-key

# Firebase (for Firestore access)
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json

# Authentication
API_PASSWORD=your-secure-password

# Agent Configuration
SCRAPE_INTERVAL_HOURS=2
MAX_STEPS_PER_JOB=50
BROWSER_TIMEOUT_MS=30000
MAX_DAILY_GEMINI_COST_USD=2.00

# Applicant Details
APPLICANT_FIRST_NAME=YourFirstName
APPLICANT_LAST_NAME=YourLastName
APPLICANT_EMAIL=your-email@example.com
APPLICANT_PHONE=+1XXXXXXXXXX
RESUME_PATH=/app/context/resume.pdf

# Search Criteria
TARGET_ROLES=Software Engineer,ML Engineer,Data Scientist
TARGET_LOCATIONS=Remote
EXPERIENCE_LEVEL=entry_level
EXCLUDED_COMPANIES=

# Service URLs (for local dev)
AGENT_BROWSER_URL=http://localhost:8080

# Context
CONTEXT_DIR=/app/context
CONTEXT_BUCKET=your-project-id-resumes
CONTEXT_PREFIX=context/
